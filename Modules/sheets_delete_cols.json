{
  "id": "sheets_delete_cols",
  "name": "列を削除",
  "icon": "fa-trash-alt",
  "category": "Google Sheets",
  "description": "指定した範囲の列を削除します。",
  "settings": [
    { "id": "targetUrl", "name": "対象スプレッドシートURL", "type": "text", "required": true },
    { "id": "targetSheet", "name": "対象シート名", "type": "text", "required": true },
    { "id": "startCol", "name": "開始列番号", "type": "number", "required": true },
    { "id": "numCols", "name": "削除する列数", "type": "number", "defaultValue": 1, "required": true }
  ],
  "logic": [
    {
      "step_id": "delete_cols",
      "func": "core.sheetsDeleteCols",
      "args": {
        "targetUrl": "{{targetUrl}}",
        "targetSheet": "{{targetSheet}}",
        "startCol": "{{startCol}}",
        "numCols": "{{numCols}}"
      }
    }
  ]
}
