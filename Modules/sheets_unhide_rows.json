{
  "id": "sheets_unhide_rows",
  "name": "行を再表示",
  "icon": "fa-eye",
  "category": "Google Sheets",
  "description": "指定した範囲の非表示になっている行を再表示します。",
  "settings": [
    { "id": "targetUrl", "name": "対象スプレッドシートURL", "type": "text", "required": true },
    { "id": "targetSheet", "name": "対象シート名", "type": "text", "required": true },
    { "id": "targetRange", "name": "対象範囲 (例: A1:A100)", "type": "text", "required": true }
  ],
  "logic": [
    {
      "step_id": "unhide_rows",
      "func": "core.sheetsUnhideRows",
      "args": {
        "targetUrl": "{{targetUrl}}",
        "targetSheet": "{{targetSheet}}",
        "targetRange": "{{targetRange}}"
      }
    }
  ]
}
