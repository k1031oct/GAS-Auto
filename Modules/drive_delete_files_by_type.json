{
  "id": "drive_delete_files_by_type",
  "name": "指定タイプのファイルを削除",
  "icon": "delete_forever",
  "category": "Google Drive",
  "description": "指定したフォルダ内にある、特定のMIMEタイプのファイルをすべてゴミ箱に移動します。",
  "settings": [
    { "id": "folderId", "name": "対象フォルダID", "type": "text", "required": true },
    { "id": "mimeType", "name": "MIMEタイプ", "type": "text", "required": true, "placeholder": "例: application/pdf" }
  ],
  "logic": [
    {
      "step_id": "delete_files_by_type",
      "func": "core.driveDeleteFilesByType",
      "args": {
        "folderId": "{{folderId}}",
        "mimeType": "{{mimeType}}"
      }
    }
  ]
}
