{
  "id": "gmail_send_email",
  "name": "Gmailを送信する",
  "icon": "fa-paper-plane",
  "category": "Gmail",
  "description": "Gmailでメールを送信します。CC, BCC, 添付ファイルも指定可能です。",
  "settings": [
    { "id": "to", "name": "宛先 (To)", "type": "text", "required": true },
    { "id": "subject", "name": "件名", "type": "text", "required": true },
    { "id": "body", "name": "本文", "type": "textarea", "required": true },
    { "id": "cc", "name": "CC", "type": "text", "required": false },
    { "id": "bcc", "name": "BCC", "type": "text", "required": false },
    { "id": "attachmentFolderId", "name": "添付ファイルがあるフォルダID（任意）", "type": "text", "required": false }
  ],
  "logic": [
    {
      "step_id": "send_email",
      "func": "core.gmailSendEmail",
      "args": {
        "to": "{{to}}",
        "subject": "{{subject}}",
        "body": "{{body}}",
        "cc": "{{cc}}",
        "bcc": "{{bcc}}",
        "attachmentFolderId": "{{attachmentFolderId}}"
      }
    }
  ]
}